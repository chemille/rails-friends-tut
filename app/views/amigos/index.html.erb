<% if user_signed_in? %>

<table class="table table-striped table-bordered table-hover">
  <thead class="thead-dark">
    <tr>
      <th>Name</th>
      <th>Phone</th>
      <th>Email</th>
      <th>Twitter</th>
      <th colspan="2"></th>
    </tr>
  </thead>
<tbody>
  <% @amigos.each do |amigo| %>
    <% if amigo.user == current_user %>
    <tr>
    <td><%= link_to amigo.first_name + ' ' + amigo.last_name, amigo %></td>
    <td><%= amigo.phone %></td>
    <td><%= amigo.email %></td>
    <td><%= amigo.twitter %></td>
    <td><%= link_to "Edit", amigo, method: :edit, class:"btn btn-outline-secondary btn-sm" %></td>
    <td class="table-danger"><%= link_to 'Delete', amigo, method: :delete, data: { confirm: 'Are you sure?' }, class:"btn btn-outline-danger btn-sm" %></td>
    </tr>
    <% end %>
  <% end %>
</tbody>
</table>
<br>

<%= link_to "New amigo", new_amigo_path, class:"btn btn-secondary" %>
<% else %>
<% end %>